NODE_ENV=development
PORT=4000

# Local
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_management?schema=public

# Supabase + Render (recomendado: Session pooler, puerto 5432)
# Supabase → Project Settings → Database → Connection string → "Session pooler"
# DATABASE_URL=postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Alternativa: Transaction pooler (puerto 6543). Requiere pgbouncer=true:
# DATABASE_URL=postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_management?schema=public
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
# Producción (Netlify). Puedes listar varios orígenes separados por coma:
# FRONTEND_URL=https://verdant-pegasus-c802d1.netlify.app,http://localhost:3000
TZ=America/La_Paz
UPLOAD_MAX_SIZE_MB=5
EXCEL_IMPORT_PATH=../../../Gimnasio_Calistenia_Gestion_v2Final (recuperacion).xlsm

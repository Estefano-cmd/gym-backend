// Gym Management - Calisthenics Gym
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  EXPIRED
  INACTIVE
  SUSPENDED
}

enum AccessStatus {
  ALLOWED
  DENIED
}

enum DurationType {
  DAYS
  MONTHS
}

enum PaymentStatus {
  CONFIRMED
  CANCELLED
}

enum TransactionStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum InventoryMovementType {
  PURCHASE
  SALE
  POSITIVE_ADJUSTMENT
  NEGATIVE_ADJUSTMENT
  RETURN
  LOSS
  DAMAGED
}

enum AttendanceMethod {
  MANUAL
  QR
  CARD
}

enum AuditAction {
  CREATE
  UPDATE
  CANCEL
  SOFT_DELETE
  REACTIVATE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  ROLE_CHANGE
  INVENTORY_ADJUSTMENT
  CONFIRM
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String     @map("last_name") @db.VarChar(100)
  phone        String?    @db.VarChar(30)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz

  roles              UserRole[]
  refreshTokens      RefreshToken[]
  clientsCreated     Client[]             @relation("ClientCreatedBy")
  paymentsCreated    MembershipPayment[]  @relation("PaymentCreatedBy")
  paymentsCancelled  MembershipPayment[]  @relation("PaymentCancelledBy")
  salesCreated       Sale[]               @relation("SaleCreatedBy")
  salesCancelled     Sale[]               @relation("SaleCancelledBy")
  purchasesCreated   Purchase[]           @relation("PurchaseCreatedBy")
  purchasesCancelled Purchase[]           @relation("PurchaseCancelledBy")
  expensesCreated    Expense[]            @relation("ExpenseCreatedBy")
  expensesCancelled  Expense[]            @relation("ExpenseCancelledBy")
  otherIncomesCreated   OtherIncome[]     @relation("OtherIncomeCreatedBy")
  otherIncomesCancelled OtherIncome[]     @relation("OtherIncomeCancelledBy")
  inventoryMovements InventoryMovement[]
  attendances        Attendance[]
  auditLogs          AuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Clients & Membership ────────────────────────────────────────────────────

model Client {
  id                    String       @id @default(uuid()) @db.Uuid
  code                  String       @unique @db.VarChar(20)
  firstName             String       @map("first_name") @db.VarChar(100)
  lastName              String       @map("last_name") @db.VarChar(100)
  documentId            String?      @unique @map("document_id") @db.VarChar(30)
  phone                 String?      @db.VarChar(30)
  email                 String?      @db.VarChar(255)
  birthDate             DateTime?    @map("birth_date") @db.Date
  gender                String?      @db.VarChar(20)
  address               String?      @db.Text
  emergencyContact      String?      @map("emergency_contact") @db.VarChar(100)
  emergencyPhone        String?      @map("emergency_phone") @db.VarChar(30)
  registrationDate      DateTime     @map("registration_date") @db.Date
  goal                  String?      @db.Text
  observations          String?      @db.Text
  status                ClientStatus @default(ACTIVE)
  coverageStartDate     DateTime?    @map("coverage_start_date") @db.Date
  coverageEndDate       DateTime?    @map("coverage_end_date") @db.Date
  accessStatus          AccessStatus @default(DENIED) @map("access_status")
  lastPaymentDate       DateTime?    @map("last_payment_date") @db.Date
  currentPlanId         String?      @map("current_plan_id") @db.Uuid
  createdById           String?      @map("created_by_id") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?    @map("deleted_at") @db.Timestamptz

  currentPlan       MembershipPlan?     @relation(fields: [currentPlanId], references: [id])
  createdBy         User?               @relation("ClientCreatedBy", fields: [createdById], references: [id])
  payments          MembershipPayment[]
  membershipPeriods MembershipPeriod[]
  sales             Sale[]
  otherIncomes      OtherIncome[]
  attendances       Attendance[]

  @@index([firstName, lastName])
  @@index([documentId])
  @@index([phone])
  @@index([status])
  @@index([coverageEndDate])
  @@index([code])
  @@map("clients")
}

model MembershipPlan {
  id              String       @id @default(uuid()) @db.Uuid
  name            String       @db.VarChar(100)
  description     String?      @db.Text
  price           Decimal      @db.Decimal(12, 2)
  durationValue   Int          @map("duration_value")
  durationType    DurationType @map("duration_type")
  isActive        Boolean      @default(true) @map("is_active")
  isPromotion     Boolean      @default(false) @map("is_promotion")
  promotionStart  DateTime?    @map("promotion_start") @db.Date
  promotionEnd    DateTime?    @map("promotion_end") @db.Date
  maxUses         Int?         @map("max_uses")
  observations    String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  clients  Client[]
  payments MembershipPayment[]

  @@index([name])
  @@index([isActive])
  @@map("membership_plans")
}

model MembershipPayment {
  id                  String        @id @default(uuid()) @db.Uuid
  code                String        @unique @db.VarChar(20)
  clientId            String        @map("client_id") @db.Uuid
  paymentDate         DateTime      @map("payment_date") @db.Date
  planId              String        @map("plan_id") @db.Uuid
  durationUnits       Int           @map("duration_units")
  unitPrice           Decimal       @map("unit_price") @db.Decimal(12, 2)
  discount            Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal       @map("total_amount") @db.Decimal(12, 2)
  paymentMethodId     String        @map("payment_method_id") @db.Uuid
  reference           String?       @db.VarChar(100)
  previousEndDate     DateTime?     @map("previous_end_date") @db.Date
  coverageStartDate   DateTime      @map("coverage_start_date") @db.Date
  coverageEndDate     DateTime      @map("coverage_end_date") @db.Date
  status              PaymentStatus @default(CONFIRMED)
  isFirstPayment      Boolean       @default(false) @map("is_first_payment")
  observations        String?       @db.Text
  cancellationReason  String?       @map("cancellation_reason") @db.Text
  cancelledById       String?       @map("cancelled_by_id") @db.Uuid
  cancelledAt         DateTime?     @map("cancelled_at") @db.Timestamptz
  createdById         String        @map("created_by_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  client        Client         @relation(fields: [clientId], references: [id])
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  paymentMethod PaymentMethod  @relation(fields: [paymentMethodId], references: [id])
  createdBy     User           @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  cancelledBy   User?          @relation("PaymentCancelledBy", fields: [cancelledById], references: [id])
  period        MembershipPeriod?

  @@index([clientId])
  @@index([paymentDate])
  @@index([status])
  @@index([code])
  @@map("membership_payments")
}

model MembershipPeriod {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  paymentId String   @unique @map("payment_id") @db.Uuid
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  client  Client            @relation(fields: [clientId], references: [id])
  payment MembershipPayment @relation(fields: [paymentId], references: [id])

  @@index([clientId])
  @@index([endDate])
  @@map("membership_periods")
}

// ─── Payment Methods & Finance ───────────────────────────────────────────────

model PaymentMethod {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  membershipPayments MembershipPayment[]
  otherIncomes       OtherIncome[]
  expenses           Expense[]
  purchases          Purchase[]
  sales              Sale[]

  @@map("payment_methods")
}

model IncomeCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  otherIncomes OtherIncome[]

  @@map("income_categories")
}

model OtherIncome {
  id              String            @id @default(uuid()) @db.Uuid
  incomeDate      DateTime          @map("income_date") @db.Date
  concept         String            @db.VarChar(255)
  categoryId      String?           @map("category_id") @db.Uuid
  clientId        String?           @map("client_id") @db.Uuid
  amount          Decimal           @db.Decimal(12, 2)
  paymentMethodId String            @map("payment_method_id") @db.Uuid
  origin          String?           @db.VarChar(100)
  reference       String?           @db.VarChar(100)
  observations    String?           @db.Text
  status          TransactionStatus @default(CONFIRMED)
  cancellationReason String?        @map("cancellation_reason") @db.Text
  cancelledById   String?           @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz
  createdById     String            @map("created_by_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  category      IncomeCategory? @relation(fields: [categoryId], references: [id])
  client        Client?         @relation(fields: [clientId], references: [id])
  paymentMethod PaymentMethod   @relation(fields: [paymentMethodId], references: [id])
  createdBy     User            @relation("OtherIncomeCreatedBy", fields: [createdById], references: [id])
  cancelledBy   User?           @relation("OtherIncomeCancelledBy", fields: [cancelledById], references: [id])

  @@index([incomeDate])
  @@index([status])
  @@map("other_incomes")
}

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id              String            @id @default(uuid()) @db.Uuid
  expenseDate     DateTime          @map("expense_date") @db.Date
  categoryId      String            @map("category_id") @db.Uuid
  description     String            @db.Text
  amount          Decimal           @db.Decimal(12, 2)
  responsible     String?           @db.VarChar(100)
  paymentMethodId String?           @map("payment_method_id") @db.Uuid
  supplierId      String?           @map("supplier_id") @db.Uuid
  reference       String?           @db.VarChar(100)
  observations    String?           @db.Text
  status          TransactionStatus @default(CONFIRMED)
  cancellationReason String?        @map("cancellation_reason") @db.Text
  cancelledById   String?           @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz
  createdById     String            @map("created_by_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethod PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  createdBy     User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  cancelledBy   User?           @relation("ExpenseCancelledBy", fields: [cancelledById], references: [id])

  @@index([expenseDate])
  @@index([categoryId])
  @@index([status])
  @@map("expenses")
}

// ─── Products & Inventory ────────────────────────────────────────────────────

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  products Product[]

  @@map("product_categories")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  sku          String   @unique @db.VarChar(50)
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  categoryId   String   @map("category_id") @db.Uuid
  purchasePrice Decimal @map("purchase_price") @db.Decimal(12, 2)
  salePrice    Decimal  @map("sale_price") @db.Decimal(12, 2)
  stock        Int      @default(0)
  minStock     Int      @default(0) @map("min_stock")
  unit         String   @default("unidad") @db.VarChar(30)
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  category           ProductCategory     @relation(fields: [categoryId], references: [id])
  inventoryMovements InventoryMovement[]
  purchaseItems      PurchaseItem[]
  saleItems          SaleItem[]

  @@index([name])
  @@index([sku])
  @@index([stock])
  @@map("products")
}

model InventoryMovement {
  id            String                @id @default(uuid()) @db.Uuid
  productId     String                @map("product_id") @db.Uuid
  movementType  InventoryMovementType @map("movement_type")
  quantity      Int
  previousStock Int                   @map("previous_stock")
  newStock      Int                   @map("new_stock")
  unitCost      Decimal?              @map("unit_cost") @db.Decimal(12, 2)
  reference     String?               @db.VarChar(100)
  reason        String?               @db.Text
  userId        String                @map("user_id") @db.Uuid
  movementDate  DateTime              @default(now()) @map("movement_date") @db.Timestamptz
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([movementDate])
  @@index([movementType])
  @@map("inventory_movements")
}

// ─── Suppliers, Purchases & Sales ────────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(30)
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(255)
  address   String?  @db.Text
  contact   String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  purchases Purchase[]
  expenses  Expense[]

  @@index([name])
  @@map("suppliers")
}

model Purchase {
  id              String            @id @default(uuid()) @db.Uuid
  code            String            @unique @db.VarChar(20)
  purchaseDate    DateTime          @map("purchase_date") @db.Date
  supplierId      String            @map("supplier_id") @db.Uuid
  totalAmount     Decimal           @map("total_amount") @db.Decimal(12, 2)
  paymentMethodId String?           @map("payment_method_id") @db.Uuid
  reference       String?           @db.VarChar(100)
  status          TransactionStatus @default(DRAFT)
  observations    String?           @db.Text
  cancellationReason String?        @map("cancellation_reason") @db.Text
  cancelledById   String?           @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz
  createdById     String            @map("created_by_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  createdBy     User           @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  cancelledBy   User?          @relation("PurchaseCancelledBy", fields: [cancelledById], references: [id])
  items         PurchaseItem[]

  @@index([purchaseDate])
  @@index([status])
  @@index([code])
  @@map("purchases")
}

model PurchaseItem {
  id         String  @id @default(uuid()) @db.Uuid
  purchaseId String  @map("purchase_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Sale {
  id              String            @id @default(uuid()) @db.Uuid
  code            String            @unique @db.VarChar(20)
  saleDate        DateTime          @map("sale_date") @db.Date
  clientId        String?           @map("client_id") @db.Uuid
  buyerName       String?           @map("buyer_name") @db.VarChar(200)
  discount        Decimal           @default(0) @db.Decimal(12, 2)
  subtotal        Decimal           @db.Decimal(12, 2)
  totalAmount     Decimal           @map("total_amount") @db.Decimal(12, 2)
  paymentMethodId String            @map("payment_method_id") @db.Uuid
  reference       String?           @db.VarChar(100)
  status          TransactionStatus @default(DRAFT)
  observations    String?           @db.Text
  cancellationReason String?        @map("cancellation_reason") @db.Text
  cancelledById   String?           @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz
  createdById     String            @map("created_by_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  client        Client?       @relation(fields: [clientId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  createdBy     User          @relation("SaleCreatedBy", fields: [createdById], references: [id])
  cancelledBy   User?         @relation("SaleCancelledBy", fields: [cancelledById], references: [id])
  items         SaleItem[]

  @@index([saleDate])
  @@index([status])
  @@index([code])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid()) @db.Uuid
  saleId    String  @map("sale_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// ─── Attendance, Attachments, Settings, Audit ────────────────────────────────

model Attendance {
  id         String           @id @default(uuid()) @db.Uuid
  clientId   String           @map("client_id") @db.Uuid
  date       DateTime         @db.Date
  checkIn    DateTime         @map("check_in") @db.Timestamptz
  checkOut   DateTime?        @map("check_out") @db.Timestamptz
  method     AttendanceMethod @default(MANUAL)
  registeredById String       @map("registered_by_id") @db.Uuid
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  client       Client @relation(fields: [clientId], references: [id])
  registeredBy User   @relation(fields: [registeredById], references: [id])

  @@index([clientId])
  @@index([date])
  @@map("attendances")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  filePath   String   @map("file_path") @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@map("attachments")
}

model Setting {
  id        String      @id @default(uuid()) @db.Uuid
  key       String      @unique @db.VarChar(100)
  value     String      @db.Text
  type      SettingType @default(STRING)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id") @db.Uuid
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SequenceCounter {
  id        String @id @default(uuid()) @db.Uuid
  name      String @unique @db.VarChar(50)
  prefix    String @db.VarChar(10)
  lastValue Int    @default(0) @map("last_value")

  @@map("sequence_counters")
}
